# Environment variables untuk finapp-wa-bot
# Copy file ini menjadi .env dan isi nilainya

# URL aplikasi Next.js kamu (lokal atau sudah di-deploy)
NEXTJS_URL=http://localhost:3000

# Secret key yang SAMA dengan BOT_API_KEY di Next.js .env.local
BOT_API_KEY=ganti_dengan_kunci_rahasia_yang_panjang_dan_acak

# Nomor WhatsApp bot ini (setelah berhasil login via QR code)
# Format: 628xxxxxxxxxx (tanpa + dan spasi)
# Ini diisi setelah bot berhasil konek pertama kali
WA_BOT_NUMBER=
